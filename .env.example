# Grabpic configuration. Copy to `.env` and tweak.

# --- Database ---
# Postgres (production / docker-compose)
# DATABASE_URL=postgresql+psycopg2://grabpic:grabpic@localhost:5432/grabpic
# SQLite (zero-config local dev)
DATABASE_URL=sqlite:///./grabpic.db

# --- Storage ---
# Directory the /ingest/scan endpoint crawls.
STORAGE_DIR=./data/images

# Directory where ONNX model weights are cached.
MODEL_DIR=./models

# --- Face recognition ---
# Cosine-similarity threshold above which two faces are "the same person".
# SFace-recommended default is 0.363.
FACE_MATCH_THRESHOLD=0.363

# Detection score cutoff for YuNet (0..1). Lower = more candidates.
FACE_DETECTION_SCORE_THRESHOLD=0.6

# Which engine to use: "opencv" (real) or "stub" (deterministic, for tests).
FACE_ENGINE=opencv

# --- API ---
API_PREFIX=/api/v1
MAX_UPLOAD_BYTES=10485760   # 10 MiB
